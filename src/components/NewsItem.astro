---
interface Props {
  title: string;
  date: Date;
  summary: string;
  link?: string;
}

const { title, date, summary, link } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="border-l-2 border-terracotta/40 pl-4">
  <p class="text-xs uppercase tracking-wide text-espresso-soft">{formattedDate}</p>
  <h3 class="mt-1 font-serif text-base font-medium text-espresso">
    {link ? <a href={link} class="hover:text-terracotta-dark">{title}</a> : title}
  </h3>
  <p class="mt-1 text-sm text-espresso-soft">{summary}</p>
</article>
