---
interface Props {
  label: string;
  href: string;
  description: string;
}

const { label, href, description } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col justify-between rounded-xl border border-tan bg-cream-card p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-terracotta/50 hover:shadow-md"
>
  <div>
    <h3 class="font-serif text-lg font-medium text-espresso">{label}</h3>
    <p class="mt-2 text-sm text-espresso-soft">{description}</p>
  </div>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-terracotta-dark">
    Explore
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </span>
</a>
