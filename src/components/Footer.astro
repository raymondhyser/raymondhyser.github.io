---
import { SITE, SOCIAL_LINKS } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-tan bg-tan-light">
  <div class="mx-auto max-w-5xl px-6 py-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="font-serif text-base font-medium text-espresso">{SITE.name}</p>
        <p class="mt-1 text-sm text-espresso-soft">{SITE.title}</p>
      </div>
      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        {
          SOCIAL_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="flex items-center gap-1.5 text-espresso-soft transition-colors hover:text-terracotta-dark"
              >
                {link.icon === "linkedin" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                    <rect width="4" height="12" x="2" y="9" />
                    <circle cx="4" cy="4" r="2" />
                  </svg>
                )}
                {link.icon === "email" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect width="20" height="16" x="2" y="4" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                )}
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <p class="mt-8 text-xs text-espresso-soft/80">
      &copy; {year} {SITE.name}. Built with Astro.
    </p>
  </div>
</footer>
