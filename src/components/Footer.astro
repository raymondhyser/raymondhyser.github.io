---
import { SITE, SOCIAL_LINKS } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-tan bg-tan-light">
  <div class="mx-auto max-w-5xl px-6 py-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="font-serif text-base font-medium text-espresso">{SITE.name}</p>
        <p class="mt-1 text-sm text-espresso-soft">{SITE.title}</p>
        <p class="mt-3 text-sm text-espresso-soft">
          <a href={`mailto:${SITE.email}`} class="hover:text-terracotta-dark">{SITE.email}</a>
        </p>
      </div>
      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        {
          SOCIAL_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-espresso-soft transition-colors hover:text-terracotta-dark">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <p class="mt-8 text-xs text-espresso-soft/80">
      &copy; {year} {SITE.name}. Built with Astro.
    </p>
  </div>
</footer>
