---
import Layout from "../layouts/Layout.astro";
import { PHILOSOPHY, PILLARS, SIGNATURE_PRACTICES, COURSES } from "../data/teaching";
---

<Layout
  title="Teaching"
  description="Teaching philosophy, courses, and classroom practices of Raymond M. Hyser III."
>
  <section class="mx-auto max-w-4xl px-6 pb-8 pt-14 sm:pt-20">
    <p class="font-serif text-base italic text-sage-dark">Teaching</p>
    <h1 class="mt-2 font-serif text-4xl font-medium leading-tight text-espresso sm:text-5xl">
      A classroom built on inclusivity, creativity, and adaptability
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-espresso-soft">
      {PHILOSOPHY}
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-16">
    <h2 class="font-serif text-2xl font-medium text-espresso">Three pillars</h2>
    <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-3">
      {
        PILLARS.map((pillar) => (
          <div class="rounded-xl border border-tan bg-cream-card p-6">
            <h3 class="font-serif text-lg font-medium text-terracotta-dark">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-espresso-soft">{pillar.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="border-t border-tan bg-tan-light/40">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <h2 class="font-serif text-2xl font-medium text-espresso">Signature practices</h2>
      <ul class="mt-6 space-y-3">
        {
          SIGNATURE_PRACTICES.map((practice) => (
            <li class="flex gap-3 rounded-lg border border-tan bg-cream-card px-4 py-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mt-0.5 shrink-0 text-sage-dark"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-sm leading-relaxed text-espresso-soft">{practice}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-6 py-16">
    <h2 class="font-serif text-2xl font-medium text-espresso">Courses taught</h2>
    <div class="mt-6 space-y-5">
      {
        COURSES.map((course) => (
          <div class="rounded-xl border border-tan bg-cream-card p-6">
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="font-serif text-lg font-medium text-espresso">{course.title}</h3>
              <span class="rounded-full border border-terracotta/40 bg-terracotta/10 px-2.5 py-0.5 text-xs font-medium text-terracotta-dark">
                {course.role}
              </span>
            </div>
            {course.description ? (
              <p class="mt-3 text-sm leading-relaxed text-espresso-soft">{course.description}</p>
            ) : (
              <p class="mt-3 text-sm italic text-espresso-soft/70">Course description coming soon.</p>
            )}
          </div>
        ))
      }
    </div>
  </section>
</Layout>
